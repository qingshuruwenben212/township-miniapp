/* 场景提示样式 */
.scene-tip {
  background-color: #e6f0ff;
  color: #048dfd;
  font-size: 14px;
  padding: 15rpx;
  border-radius: 12rpx;
  margin-bottom: 25rpx;
  text-align: center;
}

/* 提交状态提示 */
.submit-status {
  background-color: #FFF8E1;
  color: #FF9800;
  font-size: 14px;
  padding: 15rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  text-align: center;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 0.7; }
  50% { opacity: 1; }
  100% { opacity: 0.7; }
}

.status-text {
  display: inline-block;
  padding-left: 40rpx;
  position: relative;
}

.status-text::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 30rpx;
  height: 30rpx;
  border: 3rpx solid #FF9800;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: translateY(-50%) rotate(0deg); }
  100% { transform: translateY(-50%) rotate(360deg); }
}

/* 表单项目间距控制 */
.container {
  padding: 0;
  margin: 0;
}
.form-item {
  margin-bottom: 25rpx;
  margin-top: 0;
  padding: 0;
}

.form-label {
  font-size: 16px;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
  display: block;
}

/* 区域信息样式 */
.form-value {
  background-color: #f5f5f5;
  color: #999999;
  font-size: 28rpx;
  padding: 24rpx 20rpx;
  border-radius: 8rpx;
  min-height: 80rpx;
  line-height: 1.4;
  box-sizing: border-box;
  transition: all 0.3s ease;
  display: block;
}

.form-value.region-selected {
  background-color: #e6f0ff !important;
  color: #048dfd !important;
  border: 2rpx solid #048dfd !important;
  font-weight: 500 !important;
}

/* 类型选择按钮样式 */
.type-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.type-btn {
  flex: 1;
  min-width: 120rpx;
  background-color: #f5f5f5;
  color: #666666;
  border-radius: 8rpx;
  font-size: 14px;
  height: 65rpx;
  line-height: 65rpx;
}

.type-btn.active {
  background-color: #048dfd;
  color: #ffffff;
}

/* AI推荐提示样式 */
.ai-tip {
  font-size: 12px;
  color: #FF9800;
  margin-top: 10rpx;
  padding-left: 5rpx;
}

/* 输入框样式 */
.form-input {
  width: 100%;
  background-color: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 25rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  min-height: 80rpx;
  line-height: 1.4;
}

.form-input::placeholder {
  color: #999999;
  font-size: 28rpx;
}

.form-input:focus {
  border-color: #048dfd;
  outline: none;
}

/* 文本域样式 */
.form-textarea {
  width: 100%;
  background-color: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 25rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
  min-height: 200rpx;
}

.form-textarea::placeholder {
  color: #999999;
  font-size: 28rpx;
  line-height: 1.6;
}

.form-textarea:focus {
  border-color: #048dfd;
  outline: none;
}

/* 字数统计 */
.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

/* 上传按钮样式 */
.upload-buttons {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.upload-btn {
  flex: 1;
  background-color: #f5f5f5;
  color: #048dfd;
  border-radius: 8rpx;
  font-size: 14px;
  height: 75rpx;
  line-height: 75rpx;
  border: none;
}

.upload-btn[disabled] {
  opacity: 0.5;
  color: #999999;
}

/* 图片预览样式 */
.image-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.preview-item {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 语音预览样式 */
.voice-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 15rpx;
}

.voice-info {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.voice-name {
  font-size: 14px;
  color: #666666;
}

.play-btn {
  background-color: #048dfd;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 12px;
  height: 45rpx;
  line-height: 45rpx;
  padding: 0 15rpx;
  border: none;
}

/* 删除文字样式 */
.delete-text {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0,0,0,0.5);
  color: #ffffff;
  font-size: 12px;
  text-align: center;
  padding: 5rpx 0;
  box-sizing: border-box;
}

.voice-preview .delete-text {
  position: static;
  background-color: transparent;
  color: #ff3b30;
  padding: 0;
  font-size: 12px;
}

/* 提交按钮样式 */
.btn-primary {
  background-color: #048dfd;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 16px;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 20rpx;
  width: 100%;
  border: none;
}

.btn-primary[disabled] {
  background-color: #cccccc;
  color: #ffffff;
}

/* AI推荐增强样式 */
.ai-recommend-box {
  background: linear-gradient(135deg, #f0f7ff 0%, #e6f0ff 100%);
  border-left: 8rpx solid #048dfd;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 15rpx;
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ai-icon {
  font-size: 48rpx;
  line-height: 1;
}

.ai-content {
  flex: 1;
}

.ai-tip {
  font-size: 28rpx;
  color: #048dfd;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.ai-keywords {
  font-size: 24rpx;
  color: #666;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.keyword-tag {
  background: rgba(4, 141, 253, 0.1);
  color: #048dfd;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  border: 1rpx solid rgba(4, 141, 253, 0.2);
}

.ai-analyzing {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 15rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
  color: #999;
  font-size: 28rpx;
}

.analyzing-icon {
  font-size: 40rpx;
  animation: pulse 1.5s infinite;
}

/* 类型提示样式 */
.type-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  background: #f0f7ff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #048dfd;
  animation: fadeIn 0.3s ease;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  color: #666;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .feedback-form {
    padding: 20rpx;
  }
  
  .form-label {
    font-size: 15px;
  }
  
  .form-input,
  .form-textarea,
  .form-value {
    font-size: 26rpx;
    padding: 20rpx 15rpx;
  }
  
  .type-btn,
  .upload-btn {
    font-size: 13px;
  }
}