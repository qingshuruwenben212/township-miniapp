/* pages/my/settings/settings.wxss */

/* 容器样式 */
.settings-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.settings-header {
  background-color: #048dfd;
  color: white;
  padding: 60rpx 40rpx 40rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 设置卡片 */
.settings-card {
  background-color: white;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  padding: 30rpx 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 表单项目 - 保持原有两行布局 */
.form-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.readonly {
  opacity: 0.7;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.form-value {
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 头像部分 */
.avatar-section {
  display: flex;
  align-items: center;
  width: 100%;
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #f0f0f0;
}

.change-text {
  font-size: 26rpx;
  color: #048dfd;
}

/* 输入框 - 修改为居左对齐 */
.form-input {
  font-size: 28rpx;
  color: #333;
  padding: 10rpx 0;
  border: none;
  outline: none;
  width: 100%;
  text-align: left; /* 改为居左对齐 */
  background: transparent;
}

.form-input::placeholder {
  color: #999;
}

/* 区域值 */
.region-value {
  color: #666;
}

/* 只读数据的样式 */
.form-value:not(:has(.form-input)) {
  color: #666;
  line-height: 40rpx;
}




/* 操作按钮 */
.action-buttons {
  padding: 40rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.btn-save, .btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
  transition: all 0.2s;
}

.btn-save {
  background-color: #048dfd;
  color: white;
}

.btn-save:active {
  background-color: #1B5E20;
}

.btn-save[disabled] {
  background-color: #cccccc;
  color: #666666;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.btn-cancel:active {
  background-color: #e0e0e0;
}

/* 区域选择器 */
.region-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-radius: 20rpx 20rpx 0 0;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel, .picker-confirm {
  font-size: 30rpx;
  color: #666;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.picker-confirm {
  color: #048dfd;
  font-weight: 500;
}

/* 修改密码弹窗 */
.password-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 600rpx;
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.password-form {
  padding: 20rpx 30rpx;
}

.password-item {
  margin-bottom: 30rpx;
}

.password-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.password-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.password-input::placeholder {
  color: #999;
}

.modal-actions {
  display: flex;
  padding: 20rpx 30rpx 40rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-btn.cancel:active {
  background-color: #e0e0e0;
}

.modal-btn.confirm {
  background-color: #048dfd;
  color: white;
}

.modal-btn.confirm:active {
  background-color: #1B5E20;
}

.modal-btn.confirm[disabled] {
  background-color: #cccccc;
  color: #666666;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .settings-card {
    margin: 0 20rpx 20rpx;
    padding: 0 20rpx;
  }
  
  .action-buttons {
    padding: 30rpx 20rpx;
  }
  
  .modal-content {
    width: 90%;
  }
}