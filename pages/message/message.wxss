/* pages/message/message.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: white;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-title {
  display: flex;
  align-items: baseline;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.count {
  font-size: 24rpx;
  color: #048dfd;
  background: #e6f0ff;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #f8f9fa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.btn-icon {
  margin-right: 6rpx;
  font-size: 28rpx;
}

.message-list {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.message-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

/* 未读消息样式 */
.message-item.unread {
  background: #f0f7ff;
  border-left: 8rpx solid #048dfd;
}

/* 已读消息样式 */
.message-item.read {
  background: white;
  border-left: 8rpx solid transparent;
}

.message-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.message-content {
  flex: 1;
  margin-right: 60rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
}

.message-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 未读红点 */
.unread-dot {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 16rpx;
  height: 16rpx;
  background: #f44336;
  border-radius: 50%;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  background: #f8f9fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  opacity: 0.7;
}

.delete-btn:active {
  background: #ffebee;
  color: #f44336;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}