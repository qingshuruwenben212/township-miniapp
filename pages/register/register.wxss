/* pages/register/register.wxss */
.register-container {
  height: 100vh;
  background: linear-gradient(135deg, #f8f9fa 0%, #e6f0ff 100%);
}

/* 头部样式 */
.header-section {
  padding: 40rpx 30rpx;
  background: white;
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(4, 141, 253, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  flex: 1;
}

.title-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #048dfd;
  margin-bottom: 10rpx;
}

.title-sub {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.header-icon-text {
  font-size: 80rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 表单区域 */
.form-section {
  padding: 30rpx;
}

/* 表单分组 */
.form-group {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 表单项目 */
.form-item {
  margin-bottom: 40rpx;
  position: relative;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-label.required::after {
  content: '*';
  color: #f44336;
  margin-left: 6rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
  transition: all 0.3s;
}

.form-input:focus {
  border-color: #048dfd;
  background: white;
  box-shadow: 0 0 10rpx rgba(4, 141, 253, 0.2);
}

/* 输入提示 */
.input-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 密码输入框 */
.password-input {
  position: relative;
}

.password-toggle {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 10rpx 20rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  z-index: 10;
}

.toggle-text {
  font-size: 24rpx;
  color: #666;
}

/* 按钮区域 */
.button-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin: 40rpx 0;
}

.register-btn {
  height: 90rpx;
  background: linear-gradient(135deg, #048dfd 0%, #6ab0ff 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s;
}

.register-btn:active {
  opacity: 0.8;
  transform: translateY(2rpx);
}

.register-btn[disabled] {
  background: linear-gradient(135deg, #cccccc 0%, #dddddd 100%);
  color: #999;
  opacity: 0.6;
}

.back-btn {
  height: 90rpx;
  background: white;
  color: #666;
  font-size: 32rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  transition: all 0.3s;
}

.back-btn:active {
  background: #f8f9fa;
  transform: translateY(2rpx);
}

.back-btn[disabled] {
  opacity: 0.6;
  background: #f5f5f5;
}

/* 注册提示 */
.register-tips {
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 30rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #ff9800;
  margin-bottom: 15rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tips-content text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}