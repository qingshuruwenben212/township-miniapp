<!-- pages/register/register.wxml -->
<scroll-view class="register-container" scroll-y="{{true}}">
  <!-- 头部 -->
  <view class="header-section">
    <view class="header-title">
      <text class="title-text">账号注册</text>
      <text class="title-sub">请填写以下信息完成注册</text>
    </view>
    <text class="header-icon-text">📝</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 账号信息 -->
    <view class="form-group">
      <view class="group-title">账号信息</view>
      
      <view class="form-item">
        <text class="form-label required">账号</text>
        <input
          class="form-input"
          type="text"
          placeholder="3-20位字母或数字"
          maxlength="20"
          value="{{username}}"
          bindinput="handleUsernameInput"
        />
        <view class="input-tip">用于登录的用户名</view>
      </view>

      <view class="form-item">
        <text class="form-label required">密码</text>
        <view class="password-input">
          <!-- 【修复】方案一：使用 password 属性（最可靠） -->
          <input
            wx:if="{{!showPassword}}"
            class="form-input"
            password
            placeholder="6-20位密码"
            maxlength="20"
            value="{{password}}"
            bindinput="handlePasswordInput"
          />
          <input
            wx:else
            class="form-input"
            type="text"
            placeholder="6-20位密码"
            maxlength="20"
            value="{{password}}"
            bindinput="handlePasswordInput"
          />
          <view class="password-toggle" bindtap="togglePassword">
            <text class="toggle-text">{{showPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
        <view class="input-tip">建议使用字母、数字组合</view>
      </view>

      <view class="form-item">
        <text class="form-label required">确认密码</text>
        <view class="password-input">
          <!-- 【修复】方案一：使用 password 属性（最可靠） -->
          <input
            wx:if="{{!showConfirmPassword}}"
            class="form-input"
            password
            placeholder="再次输入密码"
            maxlength="20"
            value="{{confirmPassword}}"
            bindinput="handleConfirmPasswordInput"
          />
          <input
            wx:else
            class="form-input"
            type="text"
            placeholder="再次输入密码"
            maxlength="20"
            value="{{confirmPassword}}"
            bindinput="handleConfirmPasswordInput"
          />
          <view class="password-toggle" bindtap="toggleConfirmPassword">
            <text class="toggle-text">{{showConfirmPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 身份信息 -->
    <view class="form-group">
      <view class="group-title">身份信息</view>
      
      <view class="form-item">
        <text class="form-label required">真实姓名</text>
        <input
          class="form-input"
          type="text"
          placeholder="请输入真实姓名"
          maxlength="10"
          value="{{realName}}"
          bindinput="handleRealNameInput"
        />
      </view>

      <view class="form-item">
        <text class="form-label required">手机号</text>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          maxlength="11"
          value="{{phone}}"
          bindinput="handlePhoneInput"
        />
      </view>

      <view class="form-item">
        <text class="form-label required">家庭住址</text>
        <input
          class="form-input"
          type="text"
          placeholder="例如：XX村XX组XX号"
          maxlength="50"
          value="{{address}}"
          bindinput="handleAddressInput"
        />
      </view>
    </view>

    <!-- 按钮区域 -->
    <view class="button-section">
      <button
        class="register-btn"
        bindtap="handleSubmit"
        disabled="{{isLoading}}"
        loading="{{isLoading}}"
      >
        {{isLoading ? '提交中...' : '提交注册'}}
      </button>

      <button
        class="back-btn"
        bindtap="goBackToLogin"
        disabled="{{isLoading}}"
      >
        返回登录
      </button>
    </view>

    <!-- 注册提示 -->
    <view class="register-tips">
      <text class="tips-title">注册须知：</text>
      <view class="tips-content">
        <text>1. 注册后需要管理员审核通过才能登录</text>
        <text>2. 请确保填写信息真实有效</text>
        <text>3. 审核通过后，您会收到消息通知</text>
      </view>
    </view>
  </view>
</scroll-view>