/* pages/admin/pending-feedbacks/pending-feedbacks.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fc;
}

/* 顶部统计卡片 */
.stats-header {
  padding: 30rpx;
  background: linear-gradient(135deg, #048dfd 0%, #6ab0ff 100%);
}

.stats-card {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  line-height: 1.2;
}

.stat-value.warning {
  color: #ffd93e;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.5), transparent);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.search-box {
  flex: 1;
  background: white;
  border-radius: 50rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(4, 141, 253, 0.1);
}

.search-icon {
  font-size: 32rpx;
  color: #999;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}

.placeholder {
  color: #ccc;
}

.sort-btn {
  background: white;
  border-radius: 50rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 8rpx 20rpx rgba(4, 141, 253, 0.1);
}

.sort-icon {
  font-size: 32rpx;
}

.sort-text {
  font-size: 26rpx;
  color: #333;
}

/* 反馈列表 */
.feedback-list {
  height: calc(100vh - 280rpx);
  padding: 20rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-animation {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.loading-animation .dot {
  width: 20rpx;
  height: 20rpx;
  background: #048dfd;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out;
}

.loading-animation .dot:nth-child(1) { animation-delay: -0.32s; }
.loading-animation .dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 - 使用文字图标 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}

/* 反馈卡片 */
.feedback-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(4, 141, 253, 0.08);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.feedback-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 20rpx 40rpx rgba(4, 141, 253, 0.15);
  border-color: #048dfd;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #048dfd, #6ab0ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 12rpx rgba(4, 141, 253, 0.3);
}

.avatar-text {
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #999;
}

.time-tag {
  background: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.time-icon {
  font-size: 24rpx;
}

.time-text {
  font-size: 22rpx;
  color: #666;
}

/* 内容区域 */
.content-section {
  margin-bottom: 20rpx;
}

.content-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.content-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  background: #f8f9fc;
  padding: 20rpx;
  border-radius: 16rpx;
}

/* AI分析 */
.ai-analysis {
  background: #f0f7ff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.analysis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.analysis-title {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.confidence-tag {
  background: #e6f0ff;
  border: 2rpx solid #048dfd;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.confidence-text {
  font-size: 22rpx;
  color: #048dfd;
}

.analysis-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.analysis-tag {
  background: white;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.ai-warning {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 15rpx;
  padding: 10rpx 15rpx;
  background: #fff3e0;
  border-radius: 12rpx;
}

.warning-icon {
  font-size: 28rpx;
}

.warning-text {
  font-size: 24rpx;
  color: #ff9800;
}

/* 位置信息 */
.location-section {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 15rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.location-icon {
  font-size: 28rpx;
}

.location-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

/* 附件区域 */
.attachments-section {
  margin-bottom: 20rpx;
}

.images-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.image-list {
  display: inline-flex;
  gap: 10rpx;
  padding: 10rpx 0;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
}

.preview-img {
  width: 100%;
  height: 100%;
}

/* ===== 语音区域样式（新添加）- 去掉了麦克风图标 ===== */
.voice-section {
  margin-top: 20rpx;
}

.voice-player {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e8eef4;
  transition: all 0.3s ease;
}

.voice-player.playing {
  background: #e3f2fd;
  border-color: #048dfd;
}

.voice-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.voice-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.voice-duration {
  font-size: 24rpx;
  color: #999;
  background: #fff;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  border: 2rpx solid #e0e0e0;
}

.voice-play {
  width: 72rpx;
  height: 72rpx;
  background: #048dfd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(4, 141, 253, 0.3);
  transition: all 0.3s ease;
}

.voice-player.playing .voice-play {
  background: #ff9800;
  transform: scale(1.1);
}

.voice-transcript {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 2rpx solid #eef2f6;
}

.transcript-icon {
  font-size: 32rpx;
  color: #666;
  flex-shrink: 0;
}

.transcript-preview {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.view-more {
  font-size: 24rpx;
  color: #048dfd;
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(4, 141, 253, 0.1);
}

/* ===== 分类操作区样式 ===== */
.action-section {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
  margin-top: 10rpx;
}

.action-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 5rpx 0;
  -webkit-overflow-scrolling: touch;
}

.category-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 5rpx 0;
}

/* 分类标签样式 - 确保可点击且文字可见 */
.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 40rpx;
  background: #ffffff;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #333333;
  border: 2rpx solid #048dfd;
  box-shadow: 0 4rpx 12rpx rgba(4, 141, 253, 0.15);
  transition: all 0.3s ease;
  min-width: 140rpx;
  font-weight: 500;
  cursor: pointer;
  position: relative;
  z-index: 10;
  opacity: 1;
  -webkit-tap-highlight-color: rgba(4, 141, 253, 0.1);
}

.category-item.selected {
  background: linear-gradient(135deg, #048dfd, #6ab0ff);
  color: #ffffff;
  border: 2rpx solid transparent;
  transform: scale(1.05);
  box-shadow: 0 8rpx 16rpx rgba(4, 141, 253, 0.4);
  font-weight: bold;
}

.category-item:active {
  transform: scale(0.95);
  background: #f0f7ff;
}

.category-item.selected:active {
  background: linear-gradient(135deg, #048dfd, #6ab0ff);
  opacity: 0.9;
}

.category-icon {
  font-size: 32rpx;
  margin-right: 4rpx;
  color: inherit;
}

.category-name {
  font-size: 28rpx;
  font-weight: inherit;
  color: inherit;
}

/* 意见输入框 */
.opinion-section {
  margin-bottom: 20rpx;
}

.opinion-input {
  width: 100%;
  height: 140rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  border: 2rpx solid #e8e8e8;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 15rpx;
  margin-top: 10rpx;
}

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #048dfd, #6ab0ff);
  color: white;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(4, 141, 253, 0.3);
  font-weight: bold;
  cursor: pointer;
}

.submit-btn.disabled {
  opacity: 0.5;
  background: #cccccc;
  box-shadow: none;
  cursor: not-allowed;
}

.submit-btn:not(.disabled):active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 34rpx;
}

.more-btn {
  width: 88rpx;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #666;
  border: 2rpx solid #e0e0e0;
  cursor: pointer;
  -webkit-tap-highlight-color: rgba(0, 0, 0, 0.05);
}

.more-btn:active {
  background: #e8e8e8;
  transform: scale(0.95);
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.load-animation {
  display: flex;
  gap: 10rpx;
}

.load-animation .dot {
  width: 12rpx;
  height: 12rpx;
  background: #048dfd;
  border-radius: 50%;
  animation: pulse 1.4s infinite ease-in-out;
}

.load-animation .dot:nth-child(2) { animation-delay: 0.2s; }
.load-animation .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse {
  0%, 60%, 100% { transform: scale(0.6); opacity: 0.6; }
  30% { transform: scale(1); opacity: 1; }
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #ccc;
  font-size: 24rpx;
}