/* pages/admin/pending-users.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: white;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.count {
  font-size: 24rpx;
  color: #048dfd;
  margin-top: 10rpx;
}

.refresh-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #f8f9fa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.refresh-icon {
  margin-right: 10rpx;
}

.user-list {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.user-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #048dfd, #55acf4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
  margin-right: 20rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
}

.user-username {
  font-size: 24rpx;
  color: #999;
}

.user-detail {
  margin-bottom: 10rpx;
}

.user-phone, .user-address {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 5rpx;
}

.user-time {
  font-size: 22rpx;
  color: #999;
}

.user-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  text-align: center;
  min-width: 100rpx;
}

.action-btn.approve {
  background: #e8f5e8;
  color: #048dfd;
}

.action-btn.reject {
  background: #ffebee;
  color: #f44336;
}

.loading-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}