<!-- pages/login/login.wxml -->
<scroll-view class="login-container" scroll-y="{{true}}">
  <!-- Logo区域 -->
  <view class="logo-section">
    <image src="/images/default-avatar.png" mode="aspectFit" class="logo" />
    <text class="app-title">乡镇服务反馈平台</text>
    <text class="app-subtitle">本地服务 · 快速响应</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <!-- 账号输入 -->
    <view class="form-item">
      <text class="form-label">账号</text>
      <input
        class="form-input"
        type="text"
        placeholder="请输入您的账号"
        maxlength="20"
        value="{{username}}"
        bindinput="handleUsernameInput"
      />
    </view>

    <!-- 密码输入 -->
    <view class="form-item">
      <text class="form-label">密码</text>
      <input
        class="form-input"
        type="password"
        password
        placeholder="请输入密码"
        maxlength="20"
        value="{{password}}"
        bindinput="handlePasswordInput"
      />
    </view>

    <!-- 身份选择 -->
    <view class="form-item">
      <text class="form-label">登录身份</text>
      <picker
        range="{{userTypes}}"
        range-key="name"
        value="{{userTypeIndex}}"
        bindchange="handleUserTypeChange"
      >
        <view class="picker">
          {{selectedTypeName}}
        </view>
      </picker>
    </view>

    <!-- 按钮区域 -->
    <view class="button-section">
      <!-- 登录按钮 -->
      <button
        class="primary-btn"
        bindtap="handleLogin"
        disabled="{{isLoading || !username || !password || userTypeIndex === 0}}"
        loading="{{isLoading}}"
      >
        {{isLoading ? '登录中...' : '登录'}}
      </button>

      <!-- 注册按钮 -->
      <button
        class="secondary-btn"
        bindtap="handleRegister"
      >
        注册账号
      </button>
    </view>

    <!-- 提示信息 -->
    <view class="login-tips">
      <text>提示：初始账号密码均为123456</text>
    </view>

    <!-- 忘记密码 -->
    <view class="forget-password">
      <text class="forget-link" bindtap="forgetPassword">忘记密码？</text>
    </view>
  </view>
</scroll-view>