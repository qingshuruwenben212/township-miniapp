/* pages/login/login.wxss */

/* 使用 scroll-view 代替 view */
.login-container {
  height: 100vh; /* 100%视口高度 */
  background: linear-gradient(135deg, #f8f9fa 0%, #e6f0ff 100%);
}

/* 调整内部布局 */
.logo-section {
  text-align: center;
  margin: 40rpx 0 60rpx;
  padding-top: 40rpx;
}

.logo {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
}

.app-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #048dfd;
  margin-bottom: 10rpx;
}

.app-subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 表单区域 */
.form-section {
  background: white;
  border-radius: 20rpx 20rpx 0 0;
  padding: 50rpx 40rpx 80rpx; /* 增加底部padding */
  box-shadow: 0 -8rpx 30rpx rgba(46, 125, 50, 0.08);
  min-height: 60vh; /* 确保有足够高度 */
}

/* 表单项目 */
.form-item {
  margin-bottom: 40rpx;
  position: relative;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #6ab0ff;
  background: white;
}

/* 选择器样式 */
.picker {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
}

/* 按钮区域 */
.button-section {
  display: flex;
  gap: 20rpx;
  margin: 60rpx 0 40rpx;
}

.primary-btn {
  flex: 2;
  height: 90rpx;
  background: linear-gradient(135deg, #048dfd 0%, #6ab0ff 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s;
}

.primary-btn:active {
  opacity: 0.8;
  transform: translateY(2rpx);
}

.primary-btn[disabled] {
  background: linear-gradient(135deg, #cccccc 0%, #dddddd 100%);
  color: #999;
  opacity: 0.6;
}

.secondary-btn {
  flex: 1;
  height: 90rpx;
  background: white;
  color: #048dfd;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #048dfd;
  transition: all 0.3s;
}

.secondary-btn:active {
  background: rgba(46, 125, 50, 0.1);
  transform: translateY(2rpx);
}

/* 快速测试区域 */
.quick-test {
  background: #f5f9f5;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.test-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.test-buttons {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.test-btn {
  flex: 1;
  min-width: 140rpx;
  height: 70rpx;
  background: white;
  color: #048dfd;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: 1rpx solid #6ab0ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.test-btn:active {
  background: #f0f9f0;
}

/* 提示信息 */
.login-tips {
  text-align: center;
  color: #ff9800;
  font-size: 24rpx;
  margin: 20rpx 0;
  background: #fff8e1;
  padding: 15rpx;
  border-radius: 8rpx;
}

/* 忘记密码 */
.forget-password {
  text-align: center;
  margin-top: 40rpx;
}

.forget-link {
  color: #048dfd;
  font-size: 26rpx;
  text-decoration: underline;
}

.forget-link:active {
  opacity: 0.8;
}

/* 清除按钮（可选） */
.clear-btn {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  background: #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 24rpx;
}

.clear-btn:active {
  background: #ccc;
}